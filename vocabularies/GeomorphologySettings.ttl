        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/marine_reef> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/submarine_canyon> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/submarine_channel> ,
