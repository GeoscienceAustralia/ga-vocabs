        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/volcano_island> ;
    skos:prefLabel "Solid Earth Setting"@en ;
    skos:topConceptOf cs: ;
.

<https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/rocky_coast>
