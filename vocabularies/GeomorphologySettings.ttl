    skos:prefLabel "tectonic depression (BGU)"@en ;
.

<https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/tectonic_high>
    a skos:Concept ;
    skos:broader <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Solid_Earth_Setting> ;
    skos:definition "A positive relief generated by an unspecified tectonic/structural process."@en ;
    skos:inScheme cs: ;
    skos:narrower
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/back-tilted_fault_block> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/horst> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/solid-earth_compressional_ridge> ,
