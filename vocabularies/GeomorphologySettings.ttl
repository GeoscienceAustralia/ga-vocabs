cs:
    a skos:ConceptScheme ;
    reg:status <https://linked.data.gov.au/def/reg-statuses/experimental> ;
    owl:versionIRI :1 ;
    skos:definition """A vocabulary of GEOMORPHIC UNIT terms (Part 2) used in the two-part marine and coastal geomorphology classification scheme (International Seabed Geomorphology Mapping Working Group - ISGM-WG: Part 1 Morphology: [https://doi.org/10.5281/zenodo.4071940](https://doi.org/10.5281/zenodo.4071940); Part 2 Geomorphology: https://doi.org/10.5281/zenodo.7804019) to classify MORPHOLOGY FEATURES (Part 1) with their process interpretation. These UNIT terms are structured within a consistent framework design that is replicated between eleven SETTING and PROCESS categories. 

This is one of four linked ISGM-WG vocabularies. Definitions in this vocabulary are subject to intermittent review and versioning. Unless otherwise stated, all definitions are derived from the Part 2 Geomorphology report (Version 1.0: https://doi.org/10.5281/zenodo.7804019)."""@en ;
    skos:hasTopConcept
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Anthropogenic_Process> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Biogenic_Process> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Coastal_Setting> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Current-induced_Process> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Fluid_Flow_Process> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Fluvial_Setting> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Glacial_Setting> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Karst_Process> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Marine_Setting> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Mass_Movement_Process> ,
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Solid_Earth_Setting> ;
    skos:historyNote "This is one of four linked ISGM-WG vocabularies. Definitions in this vocabulary are subject to intermittent review and versioning. Unless otherwise stated, all definitions are derived from the Part 2 Geomorphology report (Version 1.0: https://doi.org/10.5281/zenodo.7804019)."@en ;
    skos:prefLabel "Marine geomorphology - Part 2 Geomorphology"@en ;
    prov:qualifiedAttribution
        [
            dcat:hadRole isoroles:custodian ;
            prov:agent
                [
                    a schema:Person ;
                    schema:email ""^^xsd:anyURI ;
                    schema:name "Orca Branch" ;
                ] ;
        ] ,
        [
            dcat:hadRole isoroles:custodian ;
            prov:agent
                [
                    a schema:Person ;
                    schema:email ""^^xsd:anyURI ;
                    schema:name "Marine And Coastal Geoscience" ;
                ] ;
        ] ;
    schema:creator
        [
            a schema:Organization ;
            schema:name "Geoscience Australia" ;
            schema:url ""^^xsd:anyURI ;
        ] ;
    schema:dateCreated "2024-06-17"^^xsd:date ;
    schema:dateModified "2024-10-16"^^xsd:date ;
    schema:publisher
        [
            a schema:Organization ;
            schema:name "Geoscience Australia" ;
            schema:url ""^^xsd:anyURI ;
        ] ;
    schema:version "1" ;
.
