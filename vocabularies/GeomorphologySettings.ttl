    skos:prefLabel "structure (BGU)"@en ;
.

<https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Marine_Setting>
    a skos:Concept ;
    skos:definition "A SETTING in which geomorphic UNITS are primarily formed below lowest astronomical tide by marine processes (waves, tides, oceanic and density currents, cumulative MASS MOVEMENT PROCESSES – e.g. SUBMARINE CANYONS)."@en ;
    skos:inScheme cs: ;
    skos:narrower
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/canyon_head> ,
