        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/washover_bar> ;
    skos:prefLabel "coastal barform (BGU)"@en ;
.

<https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/Biogenic_Process>
    a skos:Concept ;
    skos:definition "A PROCESS grouping in which geomorphic UNITS are biogenic landforms (bioconstructions and build-ups) that can predominantly be attributed to the activity of organisms at or below highest astronomical tides."@en ;
    skos:inScheme cs: ;
    skos:narrower
        <https://pid.geoscience.gov.au/def/voc/ga/GeomorphologySettings/back_reef> ,
