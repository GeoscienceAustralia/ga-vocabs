        :chenier_ridge ,
        :coastal_barform ,
        :coastal_delta ,
        :coastal_subaerial_valley ,
        :delta_lobe ,
        :floodplain ,
        :floodplain_terrace ,
        :lagoon ,
        :raised_beach ,
        :rocky_coast ,
        :shoreface ,
        :subaerial_channel ,
        :tidal_flat ;
    skos:prefLabel "Coastal Setting"@en ;
    skos:topConceptOf cs: ;
    schema:status astatus:stable ;
.

:mass_movement_process
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A PROCESS grouping in which geomorphic UNITS are primarily formed by downslope gravity-driven transport."@en ;
    skos:historyNote "2026-05: This Concept was updated in 2026 following revision and maintenance of the ISGM 2-part geomorphic classification scheme." ;
