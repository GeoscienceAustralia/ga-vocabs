        :moat ,
        :mud_volcano ,
        :mudflow_mud_volcano ,
        :permafrost_pingo_depression ,
        :pingo ,
        :pockmark ,
        :ring_fault ;
    skos:prefLabel "Fluid Flow Process"@en ;
    skos:topConceptOf cs: ;
    schema:status astatus:stable ;
.

:rocky_coast
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :coastal_setting ;
    skos:definition "Any length of coast that is predominantly characterised by rock (rather than sediment or vegetation)."@en ;
    skos:historyNote "2026-05: This Concept was updated in 2026 following revision and maintenance of the ISGM 2-part geomorphic classification scheme." ;
    skos:inScheme cs: ;
    skos:narrower
        :arch ,
