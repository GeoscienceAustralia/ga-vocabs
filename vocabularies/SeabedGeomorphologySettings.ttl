        :pothole ,
        :ramp ,
        :rampart ,
        :shore_platform ,
        :stack ,
        :toe_rocky_coast ;
    skos:prefLabel "rocky coast"@en ;
    schema:citation "https://pid.geoscience.gov.au/def/voc/ga/SeabedGeomorphologyGeneral/basic_geomorphic_unit_BGU"^^xsd:anyURI ;
    schema:status astatus:stable ;
.

:biogenic_reef
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :biogenic_process ;
    skos:definition "In-situ, positive relief, persistent build-ups of primarily skeleton-supported framework (+ internal binding), that influence the local sedimentary environment (Klement, 1967), and supports (or supported) living communities during active accretion. Definition modified from a range of sources: (Cumings, 1932; Goudie, 2006; Harris and Baker, 2020; Klement, 1967; Lo Iacono et al., 2018).Cf. REEF (MARINE SETTING)."@en ;
    skos:historyNote "2026-05: This Concept was updated in 2026 following revision and maintenance of the ISGM 2-part geomorphic classification scheme." ;
    skos:inScheme cs: ;
    skos:narrower
        :atoll ,
        :barrier_reef ,
        :cold_water-coral-reef ,
        :coralligene_bank ,
        :coralligene_rim ,
        :coralligène ,
        :crescentic_reef_mature ,
        :fringing_reef ,
        :juvenile_reef_irregular_patch_reefs ,
        :juvenile_reef_submerged_shoals ,
        :juvenile_reef_unmodified_antecedent_platform ,
        :lagoonal_reef_mature ,
        :patch_reef ,
        :planar_reef_senile ,
        :platform_reef ;
    skos:prefLabel "biogenic reef"@en ;
    schema:citation "https://pid.geoscience.gov.au/def/voc/ga/SeabedGeomorphologyGeneral/basic_geomorphic_unit_BGU"^^xsd:anyURI ;
    schema:status astatus:stable ;
.

:solid_earth_setting
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A SETTING in which bedrock UNITS are related to the configuration of the bedrock geology itself; these UNITS represent a broad range of scales and lithologies and can be the product of tectonic deformation and volcanic activity. The SOLID EARTH SETTING excludes UNITS formed by other processes (e.g. FLUVIAL - SUBAERIAL CHANNELS incised into bedrock) and is not intended to span the spectrum of geological terminology that is traditionally applied during terrestrial geology mapping."@en ;
    skos:historyNote "2026-05: This Concept was updated in 2026 following revision and maintenance of the ISGM 2-part geomorphic classification scheme." ;
    skos:inScheme cs: ;
    skos:narrower
        :abyssal_hill ,
        :axial_volcanic_ridge ,
        :bedding_ridge ,
        :bedrock_outcrop_undef ,
        :dip_slope ,
        :guyot ,
        :impact_crater ,
        :magmatic_outcrop ,
        :oceanic_core_complex ,
        :scarp_slope ,
        :tectonic_depression ,
        :tectonic_escarpment ,
        :tectonic_high ,
        :tectonic_lineament ,
        :volcano_island ;
    skos:prefLabel "Solid Earth Setting"@en ;
    skos:topConceptOf cs: ;
    schema:status astatus:stable ;
.

:coastal_setting
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A SETTING in which geomorphic UNITS are primarily formed by coastal processes (waves, tides, rivers and winds) on modern or former CONTINENTAL SHELVES (PHYSIOGRAPHY)."@en ;
    skos:historyNote "2026-05: This Concept was updated in 2026 following revision and maintenance of the ISGM 2-part geomorphic classification scheme." ;
    skos:inScheme cs: ;
    skos:narrower
