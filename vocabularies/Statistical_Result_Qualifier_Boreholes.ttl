PREFIX : <https://pid.geoscience.gov.au/def/voc/ga/StatisticalResultQualifier/>
PREFIX astatus: <https://linked.data.gov.au/def/reg-statuses/>
PREFIX cs: <https://pid.geoscience.gov.au/def/voc/ga/StatisticalResultQualifier>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX gavoc: <https://pid.geoscience.gov.au/def/voc/ga/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:maximum
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The highest numeric value of a sample set."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "maximum"@en ;
    skos:topConceptOf cs: ;
    schema:citation "http://resource.geoscience.gov.au/classifier/ga/resultqualifier/maximum"^^xsd:anyURI ;
.

:mean
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel
        "arithmetic mean"@en ,
        "average"@en ;
    skos:definition "The sum of the values in a sample, divided by the number of values in that sample."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "mean"@en ;
    skos:topConceptOf cs: ;
    schema:citation "http://resource.geoscience.gov.au/classifier/ga/resultqualifier/mean"^^xsd:anyURI ;
.

:median
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The numerical value separating the higher half of a data sample, a population, or a probability distribution, from the lower half."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "median"@en ;
    skos:topConceptOf cs: ;
    schema:citation "http://resource.geoscience.gov.au/classifier/ga/resultqualifier/median"^^xsd:anyURI ;
.

:minimum
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The lowest numeric value of a sample set."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "minimum"@en ;
    skos:topConceptOf cs: ;
    schema:citation "http://resource.geoscience.gov.au/classifier/ga/resultqualifier/minimum"^^xsd:anyURI ;
.

:mode
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The value that appears most often in a set of data."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "mode"@en ;
    skos:topConceptOf cs: ;
    schema:citation "http://resource.geoscience.gov.au/classifier/ga/resultqualifier/mode"^^xsd:anyURI ;
.

:singleMeasurementPartSample
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A single or spot measurement of part of a specimen (e.g., a spot measurement of magnetic susceptibility on a rock outcrop) which may be expected to vary with the location or attitude of the instrument on the specimen"@en ;
    skos:inScheme cs: ;
    skos:prefLabel "single measurement - part sample"@en ;
    skos:topConceptOf cs: ;
    schema:citation "http://resource.geoscience.gov.au/classifier/ga/resultqualifier/single_measurement_part_sample"^^xsd:anyURI ;
.

:singleMeasurementWholeSample
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A single or spot measurement of the whole specimen, that may be expected to give the same result if repeated."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "single measurement - whole sample"@en ;
    skos:topConceptOf cs: ;
    schema:citation "http://resource.geoscience.gov.au/classifier/ga/resultqualifier/single_measurement_whole_sample"^^xsd:anyURI ;
.

:unknown
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The statistical type of measurement value is not known."@en ;
    skos:exactMatch <http://www.opengis.net/def/nil/OGC/0/unknown> ;
    skos:inScheme cs: ;
    skos:prefLabel "unknown"@en ;
    skos:topConceptOf cs: ;
.

:weightedMean
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The sum of values in a sample, weighted proportional to their inverse variance, and divided by n-1 where n is the number of values in the population."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "weighted mean"@en ;
    skos:topConceptOf cs: ;
    schema:citation "https://en.wikipedia.org/wiki/Inverse-variance_weighting"^^xsd:anyURI ;
.

cs:
    a skos:ConceptScheme ;
    skos:definition "Statistical qualifier for rock property measurements (e.g. mean, maximum, median)."@en ;
    skos:hasTopConcept
        :maximum ,
        :mean ,
        :median ,
        :minimum ,
        :mode ,
        :singleMeasurementPartSample ,
        :singleMeasurementWholeSample ,
        :unknown ,
        :weightedMean ;
    skos:prefLabel "Geology Rock Properties - Result Qualifier"@en ;
    dcat:contactPoint "Team Lead - Information Services; Energy, Minerals and Groundwater Division" ;
    schema:citation "Geoscience Australia Statistical Result Qualifier (ROCKPROPS.LU_RESULTQUALIFIER)" ;
    schema:creator <https://linked.data.gov.au/org/ga> ;
    schema:dateCreated "2022-08-09"^^xsd:date ;
    schema:dateModified "2026-04-29"^^xsd:date ;
    schema:identifier "https://pid.geoscience.gov.au/dataset/ga/148553"^^gavoc:eCatID ;
    schema:keywords <https://pid.geoscience.gov.au/def/voc/ga/DataThemes/data_acquisition> ;
    schema:publisher <https://linked.data.gov.au/org/ga> ;
    schema:status astatus:experimental ;
    schema:version "1" ;
.
