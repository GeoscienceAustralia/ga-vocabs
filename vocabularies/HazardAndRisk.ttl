PREFIX : <https://pid.geoscience.gov.au/def/voc/ga/HazardAndRisk/>
PREFIX cs: <https://pid.geoscience.gov.au/def/voc/ga/HazardAndRisk>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX isoroles: <https://linked.data.gov.au/def/data-roles/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The atmospheric variables (temperature, rainfall, humidity, wind speed, etc.) at a particular place and time."@en ;
    skos:historyNote "http://www.bom.gov.au/climate/glossary/" ;
    skos:inScheme cs: ;
    skos:prefLabel "Weather"@en ;
    skos:topConceptOf cs: ;
.

:abnormally_high_tide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Abnormally high sea levels caused by high astronomical tides exacerbated by sea level rise and/or storm surge."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Abnormally high tide"@en ;
    skos:topConceptOf cs: ;
.

:adaptive_capacity
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The ability of a system to modify or change its characteristics and behaviours to cope with actual or anticipated stresses. These factors enable the adjustment of responses and behaviours through learning, adaptation and transformation."@en ;
    skos:historyNote "https://knowledge.aidr.org.au/resources/ajem-apr-2017-the-australian-natural-disaster-resilience-index/" ;
    skos:inScheme cs: ;
    skos:prefLabel "Adaptive capacity"@en ;
    skos:topConceptOf cs: ;
.

:administrative_data
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Administrative data is the set of units and data derived from an administrative source. (e.g. tax records or Medicare transactions)"@en ;
    skos:historyNote "OECD Glossary of Statistical Terms - Administrative data Definition" ;
    skos:inScheme cs: ;
    skos:prefLabel "Administrative data"@en ;
    skos:topConceptOf cs: ;
.

:aftershock
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :earthquake ;
    skos:definition "Smaller earthquake following the largest earthquake of a series concentrated in a restricted crustal volume."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Aftershock"@en ;
.

:agricultural
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Relating to cultivation of plants and livestock for consumption and economic benefit."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Agricultural"@en ;
    skos:topConceptOf cs: ;
.

:analysis
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Data analysis"@en ;
    skos:definition "Data analysis is the process of transforming raw data into usable information, often presented in the form of a published analytical article, in order to add value to the statistical output."@en ;
    skos:historyNote "OECD Glossary of Statistical Terms - Data analysis Definition" ;
    skos:inScheme cs: ;
    skos:prefLabel "Analysis"@en ;
    skos:topConceptOf cs: ;
.

:bathymetry
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Seabed topography"@en ;
    skos:definition "Underwater depth of ocean floors, lake floors, or river floors."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Bathymetry"@en ;
    skos:topConceptOf cs: ;
.

:biological_hazard
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Hazards of an organic origin: pathogenic microorganisms, toxins and bioactive substances that occur either naturally or are deliberately or unintentionally released."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Biological hazard"@en ;
    skos:topConceptOf cs: ;
.

:built
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Human-made surroundings, structures and supporting infrastructure to facilitate life, health, work and play."@en ;
    skos:historyNote "National Climate Resilience and Adaptation Strategy" ;
    skos:inScheme cs: ;
    skos:prefLabel "Built (domain)"@en ;
    skos:topConceptOf cs: ;
.

:burn_scar
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "fire scar"@en ;
    skos:definition "Visibly blackened land surface left after a fire has burned through vegetation."@en ;
    skos:historyNote "https://www.qld.gov.au/environment/land/management/mapping/statewide-monitoring/firescar/firescar-explained" ;
    skos:inScheme cs: ;
    skos:prefLabel "Burn scar"@en ;
    skos:topConceptOf cs: ;
.

:bushfire
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Unplanned vegetation fire. A generic term which includes grass fires, forest fires and scrub fires both with and without a suppression objective."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Bushfire"@en ;
    skos:topConceptOf cs: ;
.

:census
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A census is a survey conducted on the full set of observation objects belonging to a given population or universe. (e.g. the Australian Census of Population and Housing)"@en ;
    skos:historyNote "OECD Glossary of Statistical Terms - Census Definition" ;
    skos:inScheme cs: ;
    skos:prefLabel "Census"@en ;
    skos:topConceptOf cs: ;
.

:climate
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The climate of a locality is the synthesis of the day-to-day values of the meteorological elements that affect the locality. Climatic data are usually expressed in terms of an individual calendar month or season and are determined over a period (usually about 30 years) long enough to ensure that representative values for the month or season are obtained. This may include the future expectation of long term weather, in the order of weeks, months or years ahead."@en ;
    skos:historyNote "http://www.bom.gov.au/climate/glossary/" ;
    skos:inScheme cs: ;
    skos:prefLabel "Climate"@en ;
    skos:topConceptOf cs: ;
.

:climate_projections
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The simulated response of the climate system to a scenario of future emission or concentration of greenhouse gases (GHGs) and aerosols, generally derived using climate models."@en ;
    skos:historyNote "IPCC 5th Assessment Report, WG 1 Glossary" ;
    skos:inScheme cs: ;
    skos:prefLabel "Climate projections"@en ;
    skos:topConceptOf cs: ;
.

:coastal
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The transition zone between the land and the sea."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Coastal"@en ;
    skos:topConceptOf cs: ;
.

:communities
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Community"@en ;
    skos:definition """A community, like a family, can contribute to a person's wellbeing e.g. support and care for individuals or by helping give a sense of identity and security. Like 'family', a definition of 'community' can vary greatly. A community can be based on:
- location
- where you live or work
- those who you have immediate family ties with (by blood and/or marriage)
- shared values
- traditions
- interests
- lifestyles
- religious groups
- school communities

The boundary of a community extends beyond a physical location."""@en ;
    skos:historyNote "Family and Community - Frameworks for Australian Social Statistics" ;
    skos:inScheme cs: ;
    skos:prefLabel "Communities"@en ;
    skos:topConceptOf cs: ;
.

:consequences
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Secondary impacts"@en ;
    skos:definition "The issues arising from the impact of an event. For example, the consequences of road closures due to a flood event include lack of access to residences or blockage in supply lines. A single form of impact may have multiple consequences across different domains."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Consequence"@en ;
    skos:topConceptOf cs: ;
.

:convection
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The process generally associated with warm rising air and the formation of cloud. Local breezes, wind and thunderstorms are a result of convection in the atmosphere."@en ;
    skos:historyNote "http://www.bom.gov.au/lam/glossary/" ;
    skos:inScheme cs: ;
    skos:prefLabel "Convection"@en ;
    skos:topConceptOf cs: ;
.

:convective_cloud
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Cloud formed through convection, particularly cumulonimbus* and cumulus* clouds."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Convective cloud"@en ;
    skos:topConceptOf cs: ;
.

:coping_capacity
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The ability of people, organizations and systems, using available skills and resources, to manage adverse conditions, risk or disasters. The capacity to cope requires continuing awareness, resources and good management, both in normal times as well as during disasters or adverse conditions. Coping capacities contribute to the reduction of disaster risks."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Coping capacity"@en ;
    skos:topConceptOf cs: ;
.

:critical_infrastructure
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel
        "Essential services"@en ,
        "Lifelines"@en ;
    skos:definition "The physical structures, facilities, networks, lifelines and other assets which provide services that are essential to the social and economic functioning of a community or society."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Critical infrastructure"@en ;
    skos:topConceptOf cs: ;
.

:damage_ratio
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel
        "Damage index"@en ,
        "Loss ratio"@en ;
    skos:definition "Level of damage expressed as the ratio of repair cost to total replacement cost. Typically used to describe physical or structural losses for assets."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Damage ratio"@en ;
    skos:topConceptOf cs: ;
.

:damaging_waves
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Dangerous surf"@en ;
    skos:definition "Waves that may lead to significant beach erosion or damage to property."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Damaging waves"@en ;
    skos:topConceptOf cs: ;
.

:damaging_winds
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Sustained winds of gale force (63 km/h) or more, or wind gusts of 90 km/h or more (100 km/h or more in Tasmania)."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Damaging Winds"@en ;
    skos:topConceptOf cs: ;
.

:data
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Data are measurements or observations that are collected as a source of information. There are a variety of different types of data, and different ways to represent data."@en ;
    skos:historyNote "Statistical Language - What are Data? (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Data"@en ;
    skos:topConceptOf cs: ;
.

:data_visualisation
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Visual presentation of data to communicate the stories contained in the dataset."@en ;
    skos:historyNote "Statistical Language - Statistical Language Glossary (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Data visualisation"@en ;
    skos:topConceptOf cs: ;
.

:dataset
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A complete collection of all observations."@en ;
    skos:historyNote "Statistical Language - What are Data? (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Dataset"@en ;
    skos:topConceptOf cs: ;
.

:demographics
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "statistical data relating to the population and particular groups within it."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Demographics"@en ;
    skos:topConceptOf cs: ;
.

:destructive_winds
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Sustained winds of storm force (89 km/h) or more, or wind gusts of 125 km/h or more."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Destructive Winds"@en ;
    skos:topConceptOf cs: ;
.

:direct_economic_loss
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :economic_loss ;
    skos:definition "The monetary value of total or partial destruction of physical assets existing in the affected area. Direct economic loss is nearly equivalent to physical damage."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Direct economic loss"@en ;
.

:disaster
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel
        "catastrophe"@en ,
        "crisis"@en ;
    skos:definition "Serious disruption of the functioning of a community or a society at any scale due to hazardous events interacting with conditions of exposure, vulnerability and capacity, leading to one or more of the following: human, material, economic and environmental losses and impacts."@en ;
    skos:historyNote "Hazard Definition and Classification Review: Technical Report, UNDRR, 2020" ;
    skos:inScheme cs: ;
    skos:prefLabel "Disaster"@en ;
    skos:topConceptOf cs: ;
.

:disaster_risk
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The potential loss of life, injury, or destroyed or damaged assets which could occur to a system, society or a community in a specific period of time, determined probabilistically as a function of hazard, exposure, vulnerability and capacity."@en ;
    skos:historyNote "UN Disaster Related Statistics Framework" ;
    skos:inScheme cs: ;
    skos:prefLabel "Disaster risk"@en ;
    skos:topConceptOf cs: ;
.

:disaster_risk_mitigation
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Activities and measures to reduce or lessen existing disaster risk or to limit the adverse impacts of a hazardous event. Mitigation differs from prevention in that it is reactive to an identified and currently existing risk or impending threat. Thus, the activities mitigate for specific threats, instead of general risk prevention."@en ;
    skos:historyNote "UN Disaster Related Statistics Framework" ;
    skos:inScheme cs: ;
    skos:prefLabel "Disaster risk mitigation"@en ;
    skos:topConceptOf cs: ;
.

:disaster_risk_prevention
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Prevention"@en ;
    skos:definition "Activities with an intention to avoid potential adverse impacts of hazardous events. While certain disaster risks cannot be eliminated, prevention aims at reducing vulnerability and exposure in such contexts where, as a result, the risk of disaster is removed."@en ;
    skos:historyNote "UN Disaster Related Statistics Framework" ;
    skos:inScheme cs: ;
    skos:prefLabel "Disaster risk prevention"@en ;
    skos:topConceptOf cs: ;
.

:disaster_risk_reduction
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Reduction"@en ;
    skos:definition "Disaster risk reduction is aimed at preventing new and reducing existing disaster risk and managing residual risk, all of which contribute to strengthening resilience and therefore to the achievement of sustainable development."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Disaster risk reduction"@en ;
    skos:topConceptOf cs: ;
.

:displacement
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Movement of the population as a direct result of a hazard, including evacuations and permanent relocations of people due to a disaster."@en ;
    skos:historyNote "UN Disaster Related Statistics Framework" ;
    skos:inScheme cs: ;
    skos:prefLabel "Displacement"@en ;
    skos:topConceptOf cs: ;
.

:distribution_electricity
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Local, low-voltage electricity network to transport electricity from transmission networks to end users (households and businesses). This includes powerlines and power poles."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Distribution (electricity)"@en ;
    skos:topConceptOf cs: ;
.

:domain
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The social, economic, natural and built domains for information."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Domain"@en ;
    skos:topConceptOf cs: ;
.

:domain_modelling
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Geographic extent of a weather or climate modelling system where the variables of a model are calculated."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Domain (modelling)"@en ;
    skos:topConceptOf cs: ;
.

:drought
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Prolonged absence or marked deficiency of precipitation (rain)."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Drought"@en ;
    skos:topConceptOf cs: ;
.

:dust_storm
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A dust storm happens when strong wind picks up dust and dirt from the ground, raises it into the atmosphere and carries it over an extensive area. Dust storms can trigger health problems for some people and cause disruption to transport due to poor visibility."@en ;
    skos:historyNote "Bureau of Meteorology (source should be WMO)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Dust storm"@en ;
    skos:topConceptOf cs: ;
.

:dwelling
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Home"@en ;
    skos:broader :residential_building ;
    skos:definition "A dwelling is considered to be a suite of rooms contained within a building intended for long-term residential use, possessing cooking and bathing/shower facilities as building fixtures. A house is considered to be a detached residential building containing a single dwelling."@en ;
    skos:historyNote "Functional Classification of Buildings, January 2021 | Australian Bureau of Statistics (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Dwelling"@en ;
.

:dynamical_downscaling
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A method that derives local- to regional-scale (10 to 100 km) information from larger-scale models or data analyses, using the output of regional climate models, global models with variable spatial resolution or high-resolution global models."@en ;
    skos:historyNote "IPCC 5th Assessment Report, WG 1 Glossary" ;
    skos:inScheme cs: ;
    skos:prefLabel "Dynamical downscaling"@en ;
    skos:topConceptOf cs: ;
.

:economic_domain
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Production and consumption of goods and services - productivity, financial systems and the economy."@en ;
    skos:historyNote "National Climate Resilience and Adaptation Strategy" ;
    skos:inScheme cs: ;
    skos:prefLabel "Economic (domain)"@en ;
    skos:topConceptOf cs: ;
.

:elevation
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Height of the ground above or below a fixed reference point, most commonly a reference geoid or mean sea level."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Elevation"@en ;
    skos:topConceptOf cs: ;
.

:environmental_assets
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The naturally occurring living and non-living components of the earth, together constituting the biophysical environment, which may provide benefits to humanity (SEEA, 2012)."@en ;
    skos:historyNote "UN Disaster Related Statistics Framework" ;
    skos:inScheme cs: ;
    skos:prefLabel "Environmental assets"@en ;
    skos:topConceptOf cs: ;
.

:environmental_hazards
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Hazards that arise through degradation of the natural systems and ecosystem services upon which humanity depends."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Environmental hazards"@en ;
    skos:topConceptOf cs: ;
.

:essential_services
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel
        "Critical services"@en ,
        "critical infrastructure"@en ,
        "essential lifelines"@en ;
    skos:definition "The physical structures, facilities, networks, lifelines and other assets which provide services that are essential to the social and economic functioning of a community or society."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Essential Services"@en ;
    skos:topConceptOf cs: ;
.

:estimate
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "An estimate is a value that is inferred for a population based on data collected from a sample of units from that population."@en ;
    skos:historyNote "Statistical Language - Estimate and Projection (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Estimate"@en ;
    skos:topConceptOf cs: ;
.

:event
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "An incident or situation, which occurs in a particular place during a particular interval of time."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Event"@en ;
    skos:topConceptOf cs: ;
.

:exceedance_probability
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Annual exceedance probability"@en ;
    skos:definition "The probability that an event of a given magnitude, or any greater magnitude, will occur. Exceedance probability relates to a given time period, commonly one year."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Exceedance probability"@en ;
    skos:topConceptOf cs: ;
.

:exposure
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The location and characteristics of assets: people, infrastructure, buildings, agriculture, environmental assets, production capacities and other tangible human assets that may be at risk from a hazard across the natural, social, economic and built domains."@en ;
    skos:historyNote "https://www.undrr.org/terminology/exposure" ;
    skos:inScheme cs: ;
    skos:prefLabel "Exposure"@en ;
    skos:topConceptOf cs: ;
.

:families
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Family"@en ;
    skos:definition "Family is often thought of as a group of people who are related through blood or marriage, and often live together. However, the definition of what a family is, and the way it is structured and functions, can vary greatly depending on the individual, community and culture. Family can range from the people living together in the same dwelling, to an extended network which crosses state and country boundaries. The structure can also vary. Family can be made up of intact, blended, one parent, and step families."@en ;
    skos:historyNote "Family and Community - Frameworks for Australian Social Statistics" ;
    skos:inScheme cs: ;
    skos:prefLabel "Families"@en ;
    skos:topConceptOf cs: ;
.

:flash_flood
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :hydrometeorological_hazard ;
    skos:definition "A flood that rises quite rapidly with little or no advance warning, usually as a result of an intense rainfall over a small area or, possibly, an ice jam, a dam failure, etc."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Flash flood"@en ;
.

:flood_extent
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The geographic extent of land that has been, or might be, flooded."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Flood extent"@en ;
    skos:topConceptOf cs: ;
.

:forecast_weather
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A statement of prediction of weather variables based on a combination of computer generated materials and forecaster-input. Usually on a time scale of hours to days."@en ;
    skos:historyNote "Glossary - NOAA's National Weather Service" ;
    skos:inScheme cs: ;
    skos:prefLabel "Forecast (weather)"@en ;
    skos:topConceptOf cs: ;
.

:forecasts_data
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Forecasts speculate future values for the population with a certain level of confidence, based on current and past values as an expectation (prediction) of what will happen."@en ;
    skos:historyNote "Statistical Language - Estimate and Projection (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Forecasts (data)"@en ;
    skos:topConceptOf cs: ;
.

:granularity
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The level of detail at which data has been collected (e.g. temporal or spatial). Granularity of data refers to the size in which data fields are sub-divided, where 'granular data, fine granularity, high granularity, small granularity' would refer to highly detailed data which may be more useful for drawing insights about specific events by time or place."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Granularity"@en ;
    skos:topConceptOf cs: ;
.

:hail
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Precipitation that originates in convective clouds, such as cumulonimbus, in the form of balls or irregular pieces of ice."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Hail"@en ;
    skos:topConceptOf cs: ;
.

:hazard
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Peril"@en ;
    skos:definition "A process, phenomenon or human activity that may cause loss of life, injury or other health impacts, property damage, social and economic disruption or environmental degradation."@en ;
    skos:historyNote "UN General Assembly (2017)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Hazard"@en ;
    skos:topConceptOf cs: ;
.

:hazardous_surf
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Surf that creates unsafe conditions for swimmers, rock fishers and boaters. The thresholds for hazardous surf are based on wave height, swell direction and swell period and vary regionally"@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Hazardous surf"@en ;
    skos:topConceptOf cs: ;
.

:heatwave
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A period of abnormally hot weather lasting several days."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Heatwave"@en ;
    skos:topConceptOf cs: ;
.

:highest_astronomical_tide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :astronomical_tide ;
    skos:definition "The highest level of water that can be predicted to occur under average meteorological conditions and any combination of astronomical conditions. This level may not be reached every year."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Highest astronomical tide"@en ;
.

:household
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition """A household is defined as one or more persons, at least one of whom is at least 15 years of age, usually resident in the same private dwelling.
Note: a household does not necessarily represent a family."""@en ;
    skos:historyNote "2901.0 - Census of Population and Housing: Census Dictionary, 2016 (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Household"@en ;
    skos:topConceptOf cs: ;
.

:housing
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Residential building"@en ;
    skos:definition "A rigid, fixed and permanent structure which has a roof intended primarily to house people."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Housing"@en ;
    skos:topConceptOf cs: ;
.

:impact_forecast
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Impact-based forecasts"@en ;
    skos:definition "Impact-based forecasting combines a forecast of a weather or climate hazard and an assessment of possible impacts, including when, where and how likely the impacts are."@en ;
    skos:historyNote "UNDRR The Future of Forecasts: Impact-based Forecasting for Early Action" ;
    skos:inScheme cs: ;
    skos:prefLabel "Impact forecast"@en ;
    skos:topConceptOf cs: ;
.

:indirect_economic_loss
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :economic_loss ;
    skos:definition "A decline in economic value added as a consequence of direct economic loss and/or human and environmental impacts. This includes micro- meso- and macroeconomic impacts. Indirect losses can occur inside or outside the hazard area and often have a time lag."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Indirect economic loss"@en ;
.

:indirect_impact
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Indirect economic loss"@en ;
    skos:broader :impact ;
    skos:definition "The impacts of a disaster that are not due to the direct, physical outcomes of a hazard event (including declines in output or revenue, and impact on wellbeing of people), and generally arise from disruptions to the flow of goods and services as a result of a disaster e.g. business interruption, lost income."@en ;
    skos:historyNote "Understanding Risk: Evolution of Disaster Risk Assessment (GFDRR, 2014) and the UNDRR Global Assessment Report 2015" ;
    skos:inScheme cs: ;
    skos:prefLabel "Indirect impact"@en ;
.

:industrial
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Activities relating to the production of goods, services and materials. Typically covers agriculture, forestry and fishing, mining, manufacturing, electricity, gas, water and waste services, construction, wholesale trade and retail trade."@en ;
    skos:historyNote "Australian and New Zealand Standard Industrial Classification (ANZSIC) https://www.abs.gov.au/statistics/classifications/australian-and-new-zealand-standard-industrial-classification-anzsic/latest-release" ;
    skos:inScheme cs: ;
    skos:prefLabel "Industrial"@en ;
    skos:topConceptOf cs: ;
.

:infrastructure
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Engineered Construction"@en ;
    skos:definition "Any fixed-in-place constructed physical asset that does not have a roof. This includes road, bridges, rail lines, harbours, mine facilities, pipelines, sewerage, drainage, telecommunications, water storage and supply, recreation facilities, other heavy industry and electircity generation, transmission and distribution lines."@en ;
    skos:historyNote "Modified from ABS Engineering Construction glossary" ;
    skos:inScheme cs: ;
    skos:prefLabel "Infrastructure"@en ;
    skos:topConceptOf cs: ;
.

:integration_data
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Integration is a statistical process whereby units or industries are combined to a larger unit under consideration of the flows of intermediate deliveries that may exist between the individual units."@en ;
    skos:historyNote "OECD Glossary of Statistical Terms - Integration Definition" ;
    skos:inScheme cs: ;
    skos:prefLabel "Integration (data)"@en ;
    skos:topConceptOf cs: ;
.

:intelligence
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Value-added analysis, supported by further interpretation to make the analysis more digestible for users (e.g. through visual aids like story maps, dashboards and mapping)."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Intelligence"@en ;
    skos:topConceptOf cs: ;
.

:inundation
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The result of water covering land that would normally remain dry. This can be caused by riverine flooding, flash flooding, tsunami, storm tide, astronomical tides or other hydrometeorological events."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Inundation"@en ;
    skos:topConceptOf cs: ;
.

:lahar
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A mudslide induced by volcanic eruption either at the time of the eruption (by the mixing of hot gases, melted ice or water, and ash) or years later (by the failure of volcanic ash deposits in the presence of heavy rain)."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Lahar"@en ;
    skos:topConceptOf cs: ;
.

:land_cover
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Land cover refers to the observed physical and biological cover of the Earth’s surface and includes natural vegetation and abiotic (non-living) surfaces."@en ;
    skos:historyNote "National Land Account, Experimental Estimates methodology, 2016 | Australian Bureau of Statistics (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Land cover"@en ;
    skos:topConceptOf cs: ;
.

:land_tenure
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Land tenure is the manner in which a party holds or occupies an area of land. It is a way of identifying who has the right to use and occupy land in accordance with the different types of ownership."@en ;
    skos:historyNote "National Land Account, Experimental Estimates methodology, 2016 | Australian Bureau of Statistics (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Land tenure"@en ;
    skos:topConceptOf cs: ;
.

:land_use
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Land use reflects both (i) the activities undertaken and (ii) the institutional arrangements put in place; for a given area for the purposes of economic production, or the maintenance and restoration of environmental functions."@en ;
    skos:historyNote "National Land Account, Experimental Estimates methodology, 2016 | Australian Bureau of Statistics (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Land use"@en ;
    skos:topConceptOf cs: ;
.

:large_hail
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Hail larger than 2 cm in diameter."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Large Hail"@en ;
    skos:topConceptOf cs: ;
.

:legacy_system
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Out-dated system that continues to be used by an organisation because it still performs the functions it was initially intended to do. Legacy systems often no longer have support or maintenance and have limited opportunities for development."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Legacy system"@en ;
    skos:topConceptOf cs: ;
.

:liquefaction
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :geophysical_hazards ;
    skos:definition "Process of soil and sand behaving like a dense fluid rather than a wet solid mass during an earthquake."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Liquefaction"@en ;
.

:local_government_area
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Local Government Areas cover legally designated parts of a State or Territory for which incorporated local governing bodies have responsibility. Local Government Areas are an ABS Mesh Block approximation of gazetted local government boundaries as defined by each state and territory. ABS approximations of administrative boundaries do not match official legal boundaries and should only be used for statistical purposes."@en ;
    skos:historyNote "https://www.abs.gov.au/statistics/standards/australian-statistical-geography-standard-asgs-edition-3/jul2021-jun2026/non-abs-structures/local-government-areas" ;
    skos:inScheme cs: ;
    skos:prefLabel "Local Government Area"@en ;
    skos:topConceptOf cs: ;
.

:loss
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Impact"@en ;
    skos:definition "Quantified impact of a disaster event. Can be monetary, physical or intangible. Can relate to losses in a single element or across domains. For example, the loss associated with a flood event may include insured losses to residential, commercial and industrial assets, losses associated with business interruption."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Loss"@en ;
    skos:topConceptOf cs: ;
.

:lowest_astronomical_tide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :astronomical_tide ;
    skos:definition "The lowest tide level that can be predicted to occur under average meteorological conditions and any combination of astronomical conditions. This level may not be reached every year."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Lowest astronomical tide"@en ;
.

:major_flooding
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :flood ;
    skos:definition "In addition to Moderate flooding, extensive rural areas and/or urban areas are inundated. Many buildings may be affected above the floor level. Properties and towns are likely to be isolated and major rail and traffic routes closed. Evacuation of flood affected areas may be required. Utility services may be impacted."@en ;
    skos:historyNote "Flood Warning Services: National flood forecasting and warning service: Water Information: Bureau of Meteorology (bom.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Major flooding"@en ;
.

:marine
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Relating to the sea or ocean."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Marine"@en ;
    skos:topConceptOf cs: ;
.

:metadata
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Metadata is the information that defines and describes data. It is often referred to as data about data or information about data because it provides data users with information about the purpose, processes, and methods involved in the data collection."@en ;
    skos:historyNote "Statistical Language - What is Metadata? (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Metadata"@en ;
    skos:topConceptOf cs: ;
.

:methodology_statistical
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Theory and methods of data collection, processing and analysis."@en ;
    skos:historyNote "OECD Glossary of Statistical Terms - Statistical methodology Definition" ;
    skos:inScheme cs: ;
    skos:prefLabel "Methodology (statistical)"@en ;
    skos:topConceptOf cs: ;
.

:minor_flooding
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :flood ;
    skos:definition "Flooding that causes inconvenience. Low-lying areas next to water courses are inundated. Minor roads may be closed and low-level bridges submerged. In urban areas inundation may affect some backyards and buildings below the floor level as well as bicycle and pedestrian paths. In rural areas removal of stock and equipment may be required."@en ;
    skos:historyNote "Flood Warning Services: National flood forecasting and warning service: Water Information: Bureau of Meteorology (bom.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Minor flooding"@en ;
.

:modelling
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel
        "Models"@en ,
        "modelled data"@en ;
    skos:definition "The construction of physical, conceptual or mathematical simulations of the real world. Models help to show relationships between processes (physical, economic or social) and may be used to predict the effects of changes in land use. (Note utility is much broader than land use)"@en ;
    skos:historyNote "OECD Glossary of Statistical Terms - Modelling Definition" ;
    skos:inScheme cs: ;
    skos:prefLabel "Modelling"@en ;
    skos:topConceptOf cs: ;
.

:moderate_flooding
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :flood ;
    skos:definition "In addition to Minor flooding, the area of inundation is more substantial. Main traffic routes may be affected. Some buildings may be affected above the floor level. Evacuation of flood affected areas may be required. In rural areas removal of stock is required."@en ;
    skos:historyNote "Flood Warning Services: National flood forecasting and warning service: Water Information: Bureau of Meteorology (bom.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Moderate flooding"@en ;
.

:multi-hazard
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The specific contexts where hazardous events may occur simultaneously, cascadingly or cumulatively over time, and taking into account the potential interrelated effects."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Multi-hazard"@en ;
    skos:topConceptOf cs: ;
.

:multispectral_imagery
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Multispectral imaging combines a number of spectral imaging bands of relatively large bandwidth into a single optical system to enable extraction of additional details."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Multispectral imagery"@en ;
    skos:topConceptOf cs: ;
.

:natural
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Environmental"@en ;
    skos:definition "Landscapes, seascapes, ecosystems, agricultural lands and animal life."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Natural"@en ;
    skos:topConceptOf cs: ;
.

:neap_tide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :astronomical_tide ;
    skos:definition "The tides when the moon and sun are at right angles to each other (in relation to the earth), the effect of the attraction is somewhat reduced leading to a smaller tidal range."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Neap tide"@en ;
.

:observation_weather
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The record of the measurement or assessment of a particular meteorological variable obtained at a specific time."@en ;
    skos:historyNote "Oxford dictionary of weather https://www.oxfordreference.com/view/10.1093/acref/9780199541447.001.0001/acref-9780199541447-e-3067?rskey=U4oWx9&result=1289" ;
    skos:inScheme cs: ;
    skos:prefLabel "Observation (weather)"@en ;
    skos:topConceptOf cs: ;
.

:observed_data
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Observation (data)"@en ;
    skos:definition "In statistics an observation would mean a single data point within a dataset."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Observed data"@en ;
    skos:topConceptOf cs: ;
.

:observed_river_height
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Depth of water (in metres) at a river height measuring gauge located along the river. In most cases, a zero reading is the lowest water level that is reached during dry conditions. In many tidal areas, as well as a few inland areas, river levels are expressed in metres above mean sea level or Australian Height Datum (AHD)."@en ;
    skos:historyNote "Flood Warning Services: National flood forecasting and warning service: Water Information: Bureau of Meteorology (bom.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Observed River Height"@en ;
    skos:topConceptOf cs: ;
.

:oceanography
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The study of the physical, chemical, and biological features of the ocean."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Oceanography"@en ;
    skos:topConceptOf cs: ;
.

:peak_river_height
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Highest river height (in metres) observed during a flood event at the specified site on the river."@en ;
    skos:historyNote "Flood Warning Services: National flood forecasting and warning service: Water Information: Bureau of Meteorology (bom.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Peak River Height"@en ;
    skos:topConceptOf cs: ;
.

:physical_vulnerability
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Physical characteristics of an asset that influence the structural performance of that asset in a hazard event."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Physical vulnerability"@en ;
    skos:topConceptOf cs: ;
.

:population
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition """Australia's estimated resident population (ERP) includes all people who usually live in Australia (regardless of nationality, citizenship or visa status), with the exception of people present for foreign military, consular or diplomatic reasons.
Note: not to be confused with statistical population which has a different meaning."""@en ;
    skos:historyNote "National, state and territory population methodology, September 2021 | Australian Bureau of Statistics (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Population"@en ;
    skos:topConceptOf cs: ;
.

:predicted_river_height
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Height (in metres) to which the river is predicted to rise at the river gauge referred to in the warning. The actual depth of flood water will vary across the floodplain. Knowledge of past flood events, as well as estimates of flood levels from flood studies, are used by local Councils, emergency services and landowners to determine which areas are likely to be flooded from the predicted river height. The accuracy of these predictions will depend on a number of factors, including the type of flood forecasting model and its input data. Predicted river heights are subject to forecasting error and are regularly updated as more information becomes available during a flood event."@en ;
    skos:historyNote "Flood Warning Services: National flood forecasting and warning service: Water Information: Bureau of Meteorology (bom.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Predicted River Height"@en ;
    skos:topConceptOf cs: ;
.

:preparedness
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Arrangements to ensure that, should a crisis occur, the required resources, capabilities and services can be efficiently mobilised and deployed"@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Preparedness"@en ;
    skos:topConceptOf cs: ;
.

:prevention
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Measures to eliminate or reduce the severity of a hazard or crisis."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Prevention"@en ;
    skos:topConceptOf cs: ;
.

:projection
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A projection indicates what the future changes in a population would be if the assumptions about future trends actually occur. These assumptions are often based on patterns of change which have previously occurred. A projection is not making a prediction or forecast about what is going to happen, it is indicating what would happen if the assumptions which underpin the projection actually occur."@en ;
    skos:historyNote "Statistical Language - Estimate and Projection (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Projection"@en ;
    skos:topConceptOf cs: ;
.

:qualitative_data
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Qualitative data are measures of 'types' and may be represented by a name, symbol, or a number code."@en ;
    skos:historyNote "Statistical Language - Quantitative and Qualitative Data (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Qualitative data"@en ;
    skos:topConceptOf cs: ;
.

:quantitative_data
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Quantitative data are measures of values or counts and are expressed as numbers."@en ;
    skos:historyNote "Statistical Language - Quantitative and Qualitative Data (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Quantitative data"@en ;
    skos:topConceptOf cs: ;
.

:reconstruction
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Implementing longer-term strategies post-incident to ‘build back better’ from a crisis, including identifying sustainable development approaches and mitigation measures that may be applicable beyond the directly affected community."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Reconstruction"@en ;
    skos:topConceptOf cs: ;
.

:recovery
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Short and medium-term measures to restore or improve the livelihoods, health, economic, physical, social, cultural and environmental assets, systems and activities, of a disaster-affected community or society, aligning with the principles of sustainable development and ‘build back better’ to avoid or reduce future disaster risk."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Recovery"@en ;
    skos:topConceptOf cs: ;
.

:recurrence_interval
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel
        "Average recurrence interval"@en ,
        "Return period"@en ;
    skos:definition "The average time interval at which events equal to or greater than a certain magnitude would recur if existing natural regimes continued without change. Recurrence interval is a function of exceedance probability."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Recurrence interval"@en ;
    skos:topConceptOf cs: ;
.

:relief
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Meeting the essential needs of food, water, shelter and medicines for people affected by a crisis event."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Relief"@en ;
    skos:topConceptOf cs: ;
.

:residential
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Intended to provide accommodation to people."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Residential"@en ;
    skos:topConceptOf cs: ;
.

:resilience
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The ability of a system, community or society exposed to hazards to resist, absorb, accommodate, adapt to, transform and recover from the effects of a hazard in a timely and efficient manner, including through the preservation and restoration of its essential basic structures and functions through risk management."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Resilience"@en ;
    skos:topConceptOf cs: ;
.

:response
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Actions taken in anticipation of, during, and immediately after an emergency to ensure that its effects are minimised, and that people affected are given immediate relief and support."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Response"@en ;
    skos:topConceptOf cs: ;
.

:risk
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Disaster risk"@en ;
    skos:definition "Probability of a defined level of impact determined as a function of hazard, exposure, vulnerability and coping capacity. Metrics may include average annualised loss or return period loss levels."@en ;
    skos:historyNote "UNISDR" ;
    skos:inScheme cs: ;
    skos:prefLabel "Risk"@en ;
    skos:topConceptOf cs: ;
.

:river_alert_level
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Water level rises to this level may cause the isolation of stock in very low-lying areas. Typically below the minor flood class level, this is the level at which a river alert is issued (where available)."@en ;
    skos:historyNote "Flood Warning Services: National flood forecasting and warning service: Water Information: Bureau of Meteorology (bom.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "River alert level"@en ;
    skos:topConceptOf cs: ;
.

:river_height_bulletin
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A summary of observed river heights (metres) at selected locations and specified times within river basins."@en ;
    skos:historyNote "Flood Warning Services: National flood forecasting and warning service: Water Information: Bureau of Meteorology (bom.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "River height bulletin"@en ;
    skos:topConceptOf cs: ;
.

:satellite_imagery
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Images of the Earth captured by a satellite which orbits about the Earth. Data captured through various radiation frequencies (eg. Visible and Infrared), and used to observe (amongst others) the development of weather systems, the landscape and landforms."@en ;
    skos:historyNote "Satellite - Glossary of Meteorology (ametsoc.org)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Satellite imagery"@en ;
    skos:topConceptOf cs: ;
.

:satellite_observations
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The record of the measurement or assessment of a particular variable derived from satellite data."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Satellite observations"@en ;
    skos:topConceptOf cs: ;
.

:scenario
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A hypothetical set of circumstances that describe a disaster event and the related consequences."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Scenario"@en ;
    skos:topConceptOf cs: ;
.

:sea_level_rise
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The increase in the mean level of the world’s oceans due to the effects of global warming. Relative sea level change refers to how the height of the ocean rises or falls relative to the land at a particular location. In contrast, absolute sea level change refers to the height of the ocean surface above the center of the earth, without regard to whether nearby land is rising or falling."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Sea level rise"@en ;
    skos:topConceptOf cs: ;
.

:secondary_impact
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Consequence"@en ;
    skos:broader :impact ;
    skos:definition "Impacts arising as a result of the direct impact of a hazard event. For example, fires triggered by ruptured gas mains after an earthquake."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Secondary impact"@en ;
.

:severe_thunderstorm
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A thunderstorm with winds measuring 48 knots (90 km/h) or greater, 2 cm hail or larger, tornadoes or heavy rain which may lead to flash flooding. Severe thunderstorms may also produce torrential rain and frequent lightning."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Severe thunderstorm"@en ;
    skos:topConceptOf cs: ;
.

:severe_tropical_cyclone
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A tropical cyclone with maximum 10-minute mean winds of 118 km/h or higher."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Severe tropical cyclone"@en ;
    skos:topConceptOf cs: ;
.

:skill
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "An estimate of how well a forecast performs relative to some well-defined reference forecast (baseline) over repeated forecast trials. A skillful forecast system is usually consistently better than the baseline. There are a variety of different methods that can be used to 'score' the level of skill, which highlight different attributes of the forecast."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Skill"@en ;
    skos:topConceptOf cs: ;
.

:small_area_estimation
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Estimates produced by modelling larger scale (e.g. state or national level) survey estimates for smaller areas."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Small area estimation"@en ;
    skos:topConceptOf cs: ;
.

:social_vulnerability
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Characteristics of a person or group in terms of capacity to anticipate, cope with, resist and recover from impacts of a hazard event."@en ;
    skos:historyNote """Wisner et al. (2004); 
UNDP (https://www.undrr.org/terminology)
https://understandrisk.org/wp-content/uploads/Intro-to-social-vulnerability.pdf""" ;
    skos:inScheme cs: ;
    skos:prefLabel "Social vulnerability"@en ;
    skos:topConceptOf cs: ;
.

:space_weather
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Events triggered beyond the Earth's atmosphere that impact upon the near-Earth space environment, our technology, and on Earth itself. The primary source of space weather is the Sun, with the greatest disturbances usually caused by solar flares, coronal mass ejections and associated geomagnetic storms."@en ;
    skos:historyNote "Bureau of Meteorology: https://www.sws.bom.gov.au/Educational/1/2" ;
    skos:inScheme cs: ;
    skos:prefLabel "Space weather"@en ;
    skos:topConceptOf cs: ;
.

:spatial
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Relating to or occupying space - location. Spatially enabled data, or data with detailed location information, enables the integration of geospatial and statistical information."@en ;
    skos:historyNote "Adapted from https://www.abs.gov.au/websitedbs/D3310114.nsf/home/geography" ;
    skos:inScheme cs: ;
    skos:prefLabel "Spatial"@en ;
    skos:topConceptOf cs: ;
.

:spring_tide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :astronomical_tide ;
    skos:definition "The tides when the moon, sun and earth are in line, their combined attraction is stronger, leading to a larger tidal range."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Spring tide"@en ;
.

:statistic
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A statistic is a value that has been produced from a data collection, such as a summary measure, an estimate or projection. Statistical information is data that has been organised to serve a useful purpose."@en ;
    skos:historyNote "Statistical Language - Statistical Language Glossary (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Statistic"@en ;
    skos:topConceptOf cs: ;
.

:statistical_area_level_1
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :statistical_area ;
    skos:definition "Statistical Areas Level 1 (SA1s) are designed to maximise the geographic detail available for Census of Population and Housing data while maintaining confidentiality. Most SA1s have a population of between 200 to 800 people."@en ;
    skos:historyNote "https://www.abs.gov.au/statistics/standards/australian-statistical-geography-standard-asgs-edition-3/jul2021-jun2026" ;
    skos:inScheme cs: ;
    skos:prefLabel "Statistical Area Level 1"@en ;
.

:statistical_area_level_2
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :statistical_area ;
    skos:definition "Statistical Areas Level 2 (SA2s) are medium-sized general purpose areas built to represent communities that interact together socially and economically. Most SA2s have a population range of 3,000 to 25,000 people."@en ;
    skos:historyNote "https://www.abs.gov.au/statistics/standards/australian-statistical-geography-standard-asgs-edition-3/jul2021-jun2026" ;
    skos:inScheme cs: ;
    skos:prefLabel "Statistical Area Level 2"@en ;
.

:statistical_area_level_3
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :statistical_area ;
    skos:definition "Statistical Areas Level 3 (SA3s) are designed for the output of regional data and most have populations between 30,000 and 130,000 people."@en ;
    skos:historyNote "https://www.abs.gov.au/statistics/standards/australian-statistical-geography-standard-asgs-edition-3/jul2021-jun2026" ;
    skos:inScheme cs: ;
    skos:prefLabel "Statistical Area Level 3"@en ;
.

:statistical_area_level_4
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :statistical_area ;
    skos:definition "Statistical Areas Level 4 (SA4s) are designed for the output of a variety of regional data, and represent labour markets and the functional area of Australian capital cities. Most SA4s have a population of over 100,000 people."@en ;
    skos:historyNote "https://www.abs.gov.au/statistics/standards/australian-statistical-geography-standard-asgs-edition-3/jul2021-jun2026" ;
    skos:inScheme cs: ;
    skos:prefLabel "Statistical Area Level 4"@en ;
.

:statistical_literacy
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Statistical literacy refers to the knowledge and skills that enable data users and producers to understand, evaluate and communicate statistical data and information."@en ;
    skos:historyNote "Statistical Language - Statistical Language Glossary (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Statistical Literacy"@en ;
    skos:topConceptOf cs: ;
.

:storm_surge
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :hydrometeorological_hazard ;
    skos:definition "An abnormal rise in sea level over and above the normal (astronomical) tide levels. It can be thought of as the change in the water level due to the presence of a storm. These powerful ocean movements are caused by strong winds piling water up against the coast as a cyclone approaches."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Storm Surge"@en ;
.

:storm_tide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The water level that results from the combination of the storm surge and the normal (astronomical) tide. If the storm surge arrives at the same time as the high tide, the potential risk of inundation, flooding and erosion is greater than at a lower tide. An additional threat at this time could come from the presence of very high waves (wave run-up)."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Storm tide"@en ;
    skos:topConceptOf cs: ;
.

:submarine_landslide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :landslide ;
    skos:definition "A landslide that occurs under water."@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Submarine landslide"@en ;
.

:survey
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A survey is an investigation about the characteristics of a given population by means of collecting data from a sample of that population and estimating their characteristics through the systematic use of statistical methodology."@en ;
    skos:historyNote "OECD Glossary of Statistical Terms - Survey Definition" ;
    skos:inScheme cs: ;
    skos:prefLabel "Survey"@en ;
    skos:topConceptOf cs: ;
.

:technological_hazard
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Originate from technological or industrial conditions, dangerous procedures, infrastructure failures or specific human activities. Examples include industrial pollution, nuclear radiation, toxic wastes, dam failures, transport accidents, factory explosions, fires and chemical spills. Technological hazards also may arise directly as a result of the impacts of a natural hazard event."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Technological hazard"@en ;
    skos:topConceptOf cs: ;
.

:thunderstorm
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Convective storm"@en ;
    skos:broader :hydrometeorological_hazard ;
    skos:definition "Sudden electrical discharges manifested by a flash of light (lightning) and a sharp rumbling sound. Thunderstorms are associated with convective clouds (Cumulonimbus) and are more often accompanied by precipitation such as rain, hail or snow. They are usually shortlived and hit on only a small area."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Thunderstorm"@en ;
.

:time_series
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A time series is a collection of observations of well-defined data items obtained through repeated measurements over time."@en ;
    skos:historyNote "Statistical Language - Statistical Language Glossary (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Time series"@en ;
    skos:topConceptOf cs: ;
.

:transmission_electricity
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Networks that allow the bulk transport of electricity at high voltages (220 kilovolts and above) from generators to major demand centres."@en ;
    skos:historyNote "Australian Energy Market Commission (https://www.aemc.gov.au/energy-system/electricity/electricity-system/electricity-supply-chain)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Transmission (electricity)"@en ;
    skos:topConceptOf cs: ;
.

:tropical_cyclone
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :hydrometeorological_hazard ;
    skos:definition "Intense low pressure systems which form over warm ocean waters at low latitudes. Tropical cyclones are associated with strong winds, torrential rain and storm surges (in coastal areas). Gale force winds (greater than 63 km/h) must extend more than halfway around the storm near the centre, and winds must persist for at least 6 hours."@en ;
    skos:historyNote "Bureau of Meteorology" ;
    skos:inScheme cs: ;
    skos:prefLabel "Tropical Cyclone"@en ;
.

:tsunami
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :geophysical_hazards ;
    skos:definition "A Japanese word for 'harbour wave'. It is used to define a water wave generated by a sudden change in the sea bed resulting from an earthquake, volcanic eruption or submarine landslide."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Tsunami"@en ;
.

:volcano
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :geophysical_hazards ;
    skos:definition "An opening in the crust of the Earth that allows hot lava, volcanic ash and gases to reach the surface."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Volcano"@en ;
.

:vulnerability
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Susceptibility of assets to damage or impact from a hazard, determined by physical, social, economic and environmental factors."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Vulnerability"@en ;
    skos:topConceptOf cs: ;
.

:warning
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Dissemination of message signalling imminent hazard which may include advice on protective measures."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:prefLabel "Warning"@en ;
    skos:topConceptOf cs: ;
.

:wave_run-up
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "The rush of water up a beach after a wave reaches the shoreline. The amount of wave run-up is the vertical distance between the maximum height the rush of water reaches on the beach and the still water level. Wave run-up depends on many factors including wave height, wave period, and the slope and composition of the beach."@en ;
    skos:historyNote "https://www.qld.gov.au/environment/coasts-waterways/beach/storm/storm-glossary#runup" ;
    skos:inScheme cs: ;
    skos:prefLabel "Wave run-up"@en ;
    skos:topConceptOf cs: ;
.

:building
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A building is a rigid, fixed and permanent structure which has a roof. Its intended purpose is primarily to house people, plant, machinery, vehicles, goods or livestock. An integral feature of a building's design is the provision for regular access by persons in order to satisfy its intended use. This includes residential buidlings, commerical buildings, industrial buildings and other non-residential buildings."@en ;
    skos:historyNote "Functional Classification of Buildings, January 2021 | Australian Bureau of Statistics (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:narrower :residential_building ;
    skos:prefLabel "Building"@en ;
    skos:topConceptOf cs: ;
.

:earthquake
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :geophysical_hazards ;
    skos:definition "The vibrations of the Earth caused by the passage of seismic waves radiating from some source of elastic energy."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:narrower :aftershock ;
    skos:prefLabel "Earthquake"@en ;
.

:landslide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :geophysical_hazards ;
    skos:definition "The general term given to movement of material downslope in a mass."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:narrower :submarine_landslide ;
    skos:prefLabel "Landslide"@en ;
.

:residential_building
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Housing"@en ;
    skos:broader :building ;
    skos:definition """Buildings that contain one or more dwellings, intended for the provision of long-term accommodation. This includes detached houses, semi-detached houses, townhouses and apartments. Ancillary outbuildings not containing dwellings built adjacent to existing residential buildings, such as garden sheds, gazebos and free standing garages, are treated as residential buildings.
Other types of accommodation such as hotels, holiday rentals, hospitals and aged care facilities (excluding retirement villages) are classified as non-residential."""@en ;
    skos:historyNote "Functional Classification of Buildings, January 2021 | Australian Bureau of Statistics (abs.gov.au)" ;
    skos:inScheme cs: ;
    skos:narrower :dwelling ;
    skos:prefLabel "Residential building"@en ;
.

:tephra
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Fragments of rock ejected into the air by an erupting volcano."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:narrower :volcanic_ash ;
    skos:prefLabel "Tephra"@en ;
    skos:topConceptOf cs: ;
.

:volcanic_ash
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader
        :geophysical_hazards ,
        :tephra ;
    skos:definition "Volcanic ash consists of fragments of rock, mineral crystals, and volcanic glass, created during volcanic eruptions and measuring less than 2 mm in diameter."@en ;
    skos:historyNote "Rose, W.I.; Durant, A.J. (2009). \"Fine ash content of explosive eruptions\". Journal of Volcanology and Geothermal Research. 186 (1–2): 32–39. doi:10.1016/j.jvolgeores.2009.01.010" ;
    skos:inScheme cs: ;
    skos:prefLabel "Volcanic ash"@en ;
.

:economic_loss
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Total economic impact that consists of direct economic loss and indirect economic loss."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:narrower
        :direct_economic_loss ,
        :indirect_economic_loss ;
    skos:prefLabel "Economic loss"@en ;
    skos:topConceptOf cs: ;
.

:impact
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Consequence"@en ;
    skos:definition "The direct, adverse outcomes of a hazard event on an asset, such as the amount of damage to a building due to the effects of wind, water, fire or ground shaking."@en ;
    skos:inScheme cs: ;
    skos:narrower
        :indirect_impact ,
        :secondary_impact ;
    skos:prefLabel "Impact"@en ;
    skos:topConceptOf cs: ;
.

:flood
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:broader :hydrometeorological_hazard ;
    skos:definition "The overflowing by water of the normal confines of a stream or other body of water, or the accumulation of water by drainage over areas which are not normally submerged."@en ;
    skos:historyNote "AIDR (https://knowledge.aidr.org.au/glossary/)" ;
    skos:inScheme cs: ;
    skos:narrower
        :major_flooding ,
        :minor_flooding ,
        :moderate_flooding ;
    skos:prefLabel "Flood"@en ;
.

:astronomical_tide
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Tide"@en ;
    skos:definition "The periodic rise and fall of water along the coast due to gravitational interactions between the moon, sun and the earth."@en ;
    skos:historyNote "Queensland Government Coastal Impacts Unit" ;
    skos:inScheme cs: ;
    skos:narrower
        :highest_astronomical_tide ,
        :lowest_astronomical_tide ,
        :neap_tide ,
        :spring_tide ;
    skos:prefLabel "Astronomical tide"@en ;
    skos:topConceptOf cs: ;
.

:statistical_area
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Hierarchical geographical areas used to release and analyse a range of social, demographic and economic statistics."@en ;
    skos:historyNote "https://www.abs.gov.au/statistics/standards/australian-statistical-geography-standard-asgs-edition-3/jul2021-jun2026" ;
    skos:inScheme cs: ;
    skos:narrower
        :statistical_area_level_1 ,
        :statistical_area_level_2 ,
        :statistical_area_level_3 ,
        :statistical_area_level_4 ;
    skos:prefLabel "Statistical Area"@en ;
    skos:topConceptOf cs: ;
.

:hydrometeorological_hazard
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "Hazards resulting from the state and behaviour of the Earth's atmosphere, its interaction with the land and oceans, the weather and climate it produces and the resulting distribution of water resources."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:narrower
        :flash_flood ,
        :flood ,
        :storm_surge ,
        :thunderstorm ,
        :tropical_cyclone ;
    skos:prefLabel "Hydrometeorological hazard"@en ;
    skos:topConceptOf cs: ;
.

:geophysical_hazards
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "Geological hazards"@en ;
    skos:definition "Hazards with a geological origin, including seismogenic (earthquake-related), volcanogenic (lava flow, ash fall, lahars, pyroclastic flows) and near-surface processes (e.g. mass movement, landslides, sinkholes)."@en ;
    skos:historyNote "UNDRR (https://www.undrr.org/terminology)" ;
    skos:inScheme cs: ;
    skos:narrower
        :earthquake ,
