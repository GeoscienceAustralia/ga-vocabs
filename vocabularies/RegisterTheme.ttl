:370302
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "370302"@en ;
    skos:broader :3703 ;
    skos:definition "Describing a substance not derived from a living organism and/or not composed of carbon and hydrogen (a hydrocarbon)."@en ;
    skos:historyNote "This concept is drawn from the Legacy GA Corporate Data Classification Scheme (https://pid.geoscience.gov.au/def/voc/ga/CDCS)." ;
	skos:inScheme cs: ;
    skos:prefLabel "Inorganic geochemistry"@en ;
    schema:citation "https://linked.data.gov.au/def/anzsrc-for/2020/370302"^^xsd:anyURI ;
.

:370303
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "370303"@en ;
    skos:broader :3703 ;
    skos:definition """The study of the abundance ratios of isotopes (both stable and radioactive) of major and trace elements in rocks (e.g. Rb/Sr, Pb/U, etc.), to elucidate a number of geologic problems and processes. These include the age relationships of rocks, and the age of the Earth itself (see geochronology; isotopic dating; and radiometric dating); palaeotemperatures and geothermometry (see oxygen-isotope analysis; and geothermometer); and the provenance of natural waters, ore-forming fluids, and magmas (see isotope fractionation; smow; d/h ratio; oxygen-isotope ratio; and stable-isotope studies)."""@en ;
	skos:historyNote "This definition is drawn from Oxford Reference (https://www.oxfordreference.com/display/10.1093/oi/authority.20110803100013355)." ;
    skos:inScheme cs: ;
    skos:prefLabel "Isotope geochemistry"@en ;
    schema:citation "https://linked.data.gov.au/def/anzsrc-for/2020/370303"^^xsd:anyURI ;
.

:370304
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:altLabel "370304"@en ;
    skos:broader :3703 ;
    skos:definition "Organic geochemistry entails the application of chemical techniques to the study of organic matter and the processes which transform organic matter in the geosphere."@en ;
	skos:historyNote "This definition is drawn from Oxford Reference (https://www.oxfordreference.com/display/10.1093/oi/authority.20110803100253730)." ;
    skos:inScheme cs: ;
    skos:prefLabel "Organic geochemistry"@en ;
    schema:citation "https://linked.data.gov.au/def/anzsrc-for/2020/370304"^^xsd:anyURI ;
.

